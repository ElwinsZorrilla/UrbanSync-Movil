@using Microsoft.AspNetCore.Identity
@using UrbanSync.Web.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>UrbanSync</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
            UrbanSync
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>

                    @if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="UserManagement" asp-action="Index">Usuarios</a>
                        </li>
                    }

                    @if (User.IsInRole("Administrador") || User.IsInRole("Supervisor"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Activity" asp-action="Index">Actividades</a>
                        </li>
                    }
                }
            </ul>

            <div class="d-flex align-items-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="navbar-text text-white">
                        @User.Identity?.Name
                    </span>

                    <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                        <button class="btn btn-outline-light btn-sm">Salir</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Auth" asp-action="Login">Login</a>
                    <a class="btn btn-warning btn-sm" asp-controller="Auth" asp-action="Register">Registrarse</a>
                }
            </div>
        </div>
    </div>
</nav>

<main class="container py-4">
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>