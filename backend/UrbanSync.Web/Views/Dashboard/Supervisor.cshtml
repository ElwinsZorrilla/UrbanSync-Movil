<div class="row g-4">
    <div class="col-12">
        <div class="p-4 p-md-5 bg-white rounded-4 shadow-sm border">
            <span class="badge bg-primary mb-3">Supervisor</span>
            <h1 class="fw-bold mb-2">Panel de Supervisor</h1>
            <p class="text-muted mb-4">
                Consulta actividades del sistema y supervisa la trazabilidad de las operaciones registradas.
            </p>

            <a asp-controller="Activity" asp-action="Index" class="btn btn-dark">
                Ver actividades
            </a>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h5 class="fw-bold">Seguimiento</h5>
                <p class="text-muted mb-0">Acceso al historial de acciones ejecutadas por usuarios.</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h5 class="fw-bold">Control operativo</h5>
                <p class="text-muted mb-0">Rol preparado para validar operaciones en próximas épicas.</p>
            </div>
        </div>
    </div>
</div>