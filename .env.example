# Copia este archivo a .env y coloca valores reales. NO subas .env al repositorio.

# Contraseña del usuario sa de SQL Server (mínimo 8 caracteres: mayúscula, minúscula, dígito y símbolo).
SA_PASSWORD=Cambia_Esta_Passw0rd!

# Llave de firma del JWT (HS256). Mínimo 32 caracteres / 256 bits.
JWT_KEY=cambia-esta-llave-por-un-secreto-largo-de-al-menos-32-caracteres
